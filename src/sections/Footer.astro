---
import { Image } from 'astro:assets';

import logoIcon from '@images/logo_icon.webp';
import { ROUTES } from '@lib/utils';

const FOOTER_ROUTES = ROUTES.filter(r => r.path !== '/');

const SOCIALS = [
    {
        label: '微信',
        svg: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
    },
    {
        label: '微博',
        svg: '<circle cx="9" cy="14" r="5"/><path d="M16 5a4 4 0 0 1 4 4"/><path d="M15.5 2a7.5 7.5 0 0 1 6.5 6.5"/>',
    },
    {
        label: '抖音',
        svg: '<path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>',
    },
    {
        label: '小红书',
        svg: '<rect x="3" y="3" width="18" height="18" rx="5"/><path d="M8 8v8M8 12h3M16 8v8M14 8h4"/>',
    },
];
---

<footer class="footer">
    <div class="footer__inner shell">
        <div class="footer__grid">
            <div class="footer__brand-col">
                <a
                    class="footer__logo"
                    href="/"
                >
                    <span class="footer__logo-icon">
                        <Image
                            alt=""
                            densities={[1, 2]}
                            height={30}
                            quality="max"
                            src={logoIcon}
                        />
                    </span>
                    <span class="footer__logo-text">
                        <span class="footer__logo-zh">惠泽健康</span>
                        <span class="footer__logo-en">Huize Health</span>
                    </span>
                </a>
                <p class="footer__desc">数字健康科技平台，提供全流程、一站式的养老服务和健康管理服务。</p>
                <div class="footer__socials">
                    {SOCIALS.map(social => (
                        <span
                            aria-label={social.label}
                            class="footer__social"
                            role="button"
                            tabindex="0"
                        >
                            <svg
                                fill="none"
                                height="18"
                                stroke="rgba(255,255,255,.8)"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.8"
                                viewBox="0 0 24 24"
                                width="18"
                                set:html={social.svg}
                            />
                        </span>
                    ))}
                </div>
            </div>

            {FOOTER_ROUTES.map(route => (
                <div class="footer__col">
                    <h4 class="footer__heading">{route.label}</h4>
                    <ul class="footer__links">
                        {(route.children ?? [route]).map(child => (
                            <li>
                                <a
                                    class="footer__link"
                                    href={child.path}
                                >
                                    {child.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}

            <div class="footer__qr-col">
                <h4 class="footer__heading">关注公众号</h4>
                <div class="footer__qr-wrap">
                    <canvas
                        aria-label="惠泽健康公众号二维码"
                        class="footer__qr-canvas"
                        data-qr
                        height="200"
                        role="img"
                        width="200"
                    />
                </div>
                <p class="footer__qr-label">扫码关注 &middot; 惠泽健康公众号</p>
            </div>
        </div>

        <div class="footer__contact">
            <span>服务热线：021-5453-0907</span>
            <span>上海市闵行区元江路525号24幢别墅</span>
        </div>

        <div class="footer__legal">
            <span class="footer__copyright-text">Copyright 2019-2026 上海惠泽智通健康科技有限公司</span>
            <a
                href="https://beian.miit.gov.cn/"
                rel="noopener"
                target="_blank"
            >
                沪ICP备2022021016号-2
            </a>
            <a
                class="footer__legal-badge"
                href="https://www.beian.gov.cn/"
                rel="noopener"
                target="_blank"
            >
                <svg
                    fill="none"
                    height="13"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="13"
                >
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                </svg>
                浙公网安备33011002014839号
            </a>
        </div>
    </div>
</footer>

<script>
    function drawQR() {
        document.querySelectorAll<HTMLCanvasElement>('[data-qr]').forEach((c) => {
            const ctx = c.getContext('2d');
            if (!ctx) return;
            const N = 25;
            const quiet = 2;
            const total = N + quiet * 2;
            const px = c.width / total;
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, c.width, c.height);
            const m: number[][] = [];
            for (let i = 0; i < N; i++) {
                m[i] = [];
                for (let j = 0; j < N; j++) m[i][j] = 0;
            }
            const finder = (r: number, k: number) => {
                for (let i = 0; i < 7; i++) {
                    for (let j = 0; j < 7; j++) {
                        const edge = i === 0 || i === 6 || j === 0 || j === 6;
                        const core = i >= 2 && i <= 4 && j >= 2 && j <= 4;
                        m[r + i][k + j] = (edge || core) ? 1 : 0;
                    }
                }
            };
            finder(0, 0);
            finder(0, N - 7);
            finder(N - 7, 0);
            for (let i = 8; i < N - 8; i++) {
                m[6][i] = i % 2 === 0 ? 1 : 0;
                m[i][6] = i % 2 === 0 ? 1 : 0;
            }
            let seed = 1234567;
            const rnd = () => {
                seed = (seed * 1103515245 + 12345) & 0x7fffffff;
                return (seed >> 8) / 0x800000;
            };
            const inFinder = (i: number, j: number) =>
                (i < 8 && j < 8) || (i < 8 && j >= N - 8) || (i >= N - 8 && j < 8);
            for (let i = 0; i < N; i++) {
                for (let j = 0; j < N; j++) {
                    if (inFinder(i, j) || i === 6 || j === 6) continue;
                    if (rnd() > 0.52) m[i][j] = 1;
                }
            }
            ctx.fillStyle = '#0A2E29';
            for (let i = 0; i < N; i++) {
                for (let j = 0; j < N; j++) {
                    if (m[i][j]) {
                        const x = (j + quiet) * px;
                        const y = (i + quiet) * px;
                        ctx.fillRect(Math.floor(x), Math.floor(y), Math.ceil(px), Math.ceil(px));
                    }
                }
            }
        });
    }

    document.addEventListener('astro:page-load', () => {
        setTimeout(drawQR, 80);
    });
</script>

<style>
    .footer {
        background: var(--color-forest);
        color: rgba(255, 255, 255, 0.7);
    }

    .footer__inner {
        padding-bottom: 0;
        padding-top: clamp(56px, 7vw, 84px);
    }

    .footer__grid {
        display: grid;
        gap: 46px;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    }

    .footer__brand-col {
        min-width: 200px;
        padding-right: clamp(0px, 2.5vw, 36px);
    }

    .footer__logo {
        align-items: center;
        display: flex;
        gap: 12px;
    }

    .footer__logo-icon {
        align-items: center;
        background: #ffffff;
        border-radius: 12px;
        display: flex;
        height: 40px;
        justify-content: center;
        width: 40px;
    }

    .footer__logo-text {
        display: flex;
        flex-direction: column;
        line-height: 1;
    }

    .footer__logo-zh {
        color: #ffffff;
        font-family: var(--font-display);
        font-size: 19px;
        font-weight: 700;
        letter-spacing: 2px;
    }

    .footer__logo-en {
        color: rgba(255, 255, 255, 0.45);
        font-family: var(--font-label);
        font-size: 9px;
        letter-spacing: 3px;
        margin-top: 4px;
        text-transform: uppercase;
    }

    .footer__desc {
        color: rgba(255, 255, 255, 0.55);
        font-size: 13.5px;
        font-weight: 300;
        line-height: 1.9;
        margin-bottom: 0;
        margin-top: 20px;
        max-width: 260px;
    }

    .footer__socials {
        display: flex;
        gap: 10px;
        margin-top: 22px;
    }

    .footer__social {
        align-items: center;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        height: 40px;
        justify-content: center;
        transition: background var(--duration-fast), border-color var(--duration-fast);
        width: 40px;
    }

    .footer__social:hover {
        background: var(--color-jade);
        border-color: var(--color-jade);
    }

    .footer__social:active {
        background: var(--color-jade-deep);
        border-color: var(--color-jade-deep);
    }

    .footer__heading {
        color: #ffffff;
        font-family: var(--font-display);
        font-size: 15.5px;
        font-weight: 600;
        letter-spacing: 1px;
        margin-bottom: 18px;
        margin-top: 0;
    }

    .footer__links {
        display: flex;
        flex-direction: column;
        gap: 12px;
        list-style: none;
        padding: 0;
    }

    .footer__link {
        color: rgba(255, 255, 255, 0.6);
        font-size: 13.5px;
        transition: color var(--duration-fast);
    }

    .footer__link:hover {
        color: #ffffff;
    }

    .footer__link:active {
        opacity: 0.8;
    }

    .footer__qr-col {
        min-width: 150px;
    }

    .footer__qr-wrap {
        background: #ffffff;
        border-radius: 15px;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
        height: 124px;
        padding: 11px;
        width: 124px;
    }

    .footer__qr-canvas {
        border-radius: 6px;
        display: block;
        height: 100%;
        width: 100%;
    }

    .footer__qr-label {
        color: rgba(255, 255, 255, 0.5);
        font-size: 12px;
        letter-spacing: 0.5px;
        margin-bottom: 0;
        margin-top: 14px;
    }

    .footer__contact {
        align-items: center;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.55);
        display: flex;
        flex-wrap: wrap;
        font-size: 13px;
        gap: 8px 26px;
        justify-content: space-between;
        margin-top: 48px;
        padding: 26px 0;
    }

    .footer__legal {
        border-top: 1px solid rgba(255, 255, 255, 0.07);
        color: rgba(255, 255, 255, 0.4);
        display: flex;
        flex-wrap: wrap;
        font-family: var(--font-label), sans-serif;
        font-size: 12px;
        gap: 6px 22px;
        letter-spacing: 0.5px;
        padding: 20px 0 30px;
    }

    .footer__legal a {
        color: rgba(255, 255, 255, 0.4);
        transition: color var(--duration-fast);
    }

    .footer__legal a:hover {
        color: rgba(255, 255, 255, 0.78);
    }

    .footer__legal a:active {
        opacity: 0.8;
    }

    .footer__legal-badge {
        align-items: center;
        display: inline-flex;
        gap: 6px;
    }

    .footer__copyright-text {
        text-transform: uppercase;
    }
</style>
