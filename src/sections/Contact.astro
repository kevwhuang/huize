---
const SERVICE_TYPES = ['康养服务', '健康管理', '保险服务', '高端定制', '其他'];
---

<section
    aria-labelledby="contact-title"
    class="shell py-[clamp(64px,8vw,116px)]"
    id="contact"
>
    <div class="flex flex-wrap gap-[clamp(34px,4vw,56px)]">
        <div class="contact__left min-w-0 flex-[1.3_1_420px]">
            <div class="flex items-center gap-3">
                <span class="h-0.5 w-[30px] bg-gold" />
                <span class="font-label text-xs font-medium uppercase tracking-[3px] text-gold">Contact Us</span>
            </div>
            <h2
                class="mt-4 font-display text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-wide text-pine"
                id="contact-title"
            >
                联系我们
            </h2>
            <p class="mb-[30px] mt-3 text-base font-light text-sage-light">
                留下您的需求，专属健康顾问将尽快与您联系
            </p>

            <div
                class="contact__success hidden rounded-[18px] border border-laurel bg-white p-[48px_36px] text-center shadow-[0_16px_40px_rgba(7,58,51,.07)]"
                id="contact-success"
            >
                <span class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-mint">
                    <svg
                        fill="none"
                        height="30"
                        stroke="#0E7C6B"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        viewBox="0 0 24 24"
                        width="30"
                    >
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                </span>
                <h3 class="mt-5 font-display text-[23px] font-bold text-pine">提交成功</h3>
                <p class="mt-3 text-[15px] font-light text-sage">感谢您的咨询，我们将尽快与您取得联系。</p>
                <button
                    class="mt-[26px] rounded-[11px] bg-jade px-[30px] py-3.5 text-[15px] font-medium text-white transition-colors duration-[var(--duration-fast)] hover:bg-jade-deep active:opacity-80"
                    id="contact-reset"
                    type="button"
                >
                    重新填写
                </button>
            </div>

            <form
                class="contact__form rounded-[18px] border border-silk bg-white p-[clamp(24px,3vw,38px)] shadow-[0_16px_40px_rgba(7,58,51,.06)]"
                id="contact-form"
                novalidate
            >
                <div class="grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-[18px]">
                    <label class="block">
                        <span class="mb-[9px] block text-[13.5px] font-medium text-sage-dark">
                            姓名 <span class="text-coral">*</span>
                        </span>
                        <input
                            aria-describedby="error-name"
                            class="contact__input w-full rounded-[11px] border border-stone bg-dew px-4 py-3.5 text-[15px] text-cedar outline-none transition-[border-color,background] duration-[var(--duration-fast)] focus:border-jade focus:bg-white"
                            name="name"
                            placeholder="请输入您的姓名"
                            required
                            type="text"
                        />
                    </label>
                    <label class="block">
                        <span class="mb-[9px] block text-[13.5px] font-medium text-sage-dark">
                            电话 <span class="text-coral">*</span>
                        </span>
                        <input
                            aria-describedby="error-phone"
                            class="contact__input w-full rounded-[11px] border border-stone bg-dew px-4 py-3.5 text-[15px] text-cedar outline-none transition-[border-color,background] duration-[var(--duration-fast)] focus:border-jade focus:bg-white"
                            name="phone"
                            placeholder="请输入您的联系电话"
                            required
                            type="tel"
                        />
                    </label>
                </div>
                <label class="mt-[18px] block">
                    <span class="mb-[9px] block text-[13.5px] font-medium text-sage-dark">服务类型</span>
                    <select
                        class="contact__input w-full appearance-none rounded-[11px] border border-stone bg-dew px-4 py-3.5 text-[15px] text-cedar outline-none transition-[border-color,background] duration-[var(--duration-fast)] focus:border-jade focus:bg-white"
                        name="type"
                    >
                        <option value="">请选择服务类型</option>
                        {SERVICE_TYPES.map(t => (
                            <option value={t}>{t}</option>
                        ))}
                    </select>
                </label>
                <label class="mt-[18px] block">
                    <span class="mb-[9px] block text-[13.5px] font-medium text-sage-dark">留言</span>
                    <textarea
                        class="contact__input w-full resize-y rounded-[11px] border border-stone bg-dew px-4 py-3.5 font-sans text-[15px] text-cedar outline-none transition-[border-color,background] duration-[var(--duration-fast)] focus:border-jade focus:bg-white"
                        name="message"
                        placeholder="请描述您的具体需求"
                        rows="4"
                    />
                </label>
                <p
                    class="contact__error mt-3.5 hidden text-[13px] text-coral"
                    id="error-name"
                >
                    请填写您的姓名。
                </p>
                <p
                    class="contact__error mt-2 hidden text-[13px] text-coral"
                    id="error-phone"
                >
                    请填写有效的联系电话。
                </p>
                <button
                    class="mt-6 w-full rounded-xl bg-jade py-4 text-base font-medium tracking-wide text-white shadow-[0_14px_30px_rgba(14,124,107,.26)] transition-[background,transform] duration-[var(--duration-fast)] hover:translate-y-[-2px] hover:bg-jade-deep active:translate-y-0 disabled:cursor-not-allowed disabled:opacity-50"
                    type="submit"
                >
                    立即咨询
                </button>
            </form>
        </div>

        <div class="contact__right min-w-0 flex-[1_1_300px]">
            <div class="relative h-full overflow-hidden rounded-[18px] bg-pine p-[clamp(28px,3vw,40px)] shadow-[0_22px_50px_rgba(7,58,51,.2)]">
                <div class="absolute -right-[70px] -top-[70px] h-60 w-60 rounded-full bg-[radial-gradient(circle,rgba(255,255,255,.06),transparent_70%)]" />
                <h3 class="relative font-display text-[22px] font-semibold tracking-wide text-white">联系方式</h3>
                <p class="relative mt-3 text-sm font-light leading-[1.8] text-white/65">
                    无论是养老照护还是医疗咨询，惠泽都在您身边。
                </p>
                <div class="relative mt-[34px] flex flex-col gap-6">
                    <div class="flex items-start gap-[15px]">
                        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/[.08]">
                            <svg
                                fill="none"
                                height="19"
                                stroke="#9ed3c6"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                viewBox="0 0 24 24"
                                width="19"
                            >
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
                            </svg>
                        </span>
                        <div>
                            <div class="font-label text-[11px] uppercase tracking-[1.5px] text-white/50">服务热线</div>
                            <div class="mt-[5px] font-display text-[19px] tracking-wide text-white">021-5453-0907</div>
                        </div>
                    </div>
                    <div class="flex items-start gap-[15px]">
                        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/[.08]">
                            <svg
                                fill="none"
                                height="19"
                                stroke="#9ed3c6"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                viewBox="0 0 24 24"
                                width="19"
                            >
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                <circle cx="12" cy="10" r="3" />
                            </svg>
                        </span>
                        <div>
                            <div class="font-label text-[11px] uppercase tracking-[1.5px] text-white/50">公司地址</div>
                            <div class="mt-[5px] text-[15px] leading-[1.6] text-white/[.92]">
                                上海市闵行区元江路<br />525号24幢别墅
                            </div>
                        </div>
                    </div>
                    <div class="flex items-start gap-[15px]">
                        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white/[.08]">
                            <svg
                                fill="none"
                                height="19"
                                stroke="#9ed3c6"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                viewBox="0 0 24 24"
                                width="19"
                            >
                                <circle cx="12" cy="12" r="10" />
                                <line x1="2" x2="22" y1="12" y2="12" />
                                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                            </svg>
                        </span>
                        <div>
                            <div class="font-label text-[11px] uppercase tracking-[1.5px] text-white/50">公司网址</div>
                            <div class="mt-[5px] text-[15px] text-white/[.92]">www.huizehealth.com</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('astro:page-load', initContact);

    function initContact() {
        const controller = new AbortController();
        const signal = controller.signal;

        const form = document.getElementById('contact-form') as HTMLFormElement | null;
        const success = document.getElementById('contact-success');
        const resetBtn = document.getElementById('contact-reset');
        const errorName = document.getElementById('error-name');
        const errorPhone = document.getElementById('error-phone');

        function showForm() {
            if (form) form.classList.remove('hidden');
            if (success) success.classList.add('hidden');
            if (form) form.reset();
            form?.querySelectorAll<HTMLElement>('.contact__input').forEach((element) => {
                element.style.borderColor = '';
            });
            errorName?.classList.add('hidden');
            errorPhone?.classList.add('hidden');
        }

        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                const data = new FormData(form);
                const name = (data.get('name') as string || '').trim();
                const phone = (data.get('phone') as string || '').trim();
                const phoneValid = /^[0-9\-\s+]{6,}$/.test(phone);

                const nameInput = form.querySelector<HTMLElement>('input[name="name"]');
                const phoneInput = form.querySelector<HTMLElement>('input[name="phone"]');

                let hasError = false;

                if (!name) {
                    errorName?.classList.remove('hidden');
                    if (nameInput) nameInput.style.borderColor = 'var(--color-coral)';
                    hasError = true;
                } else {
                    errorName?.classList.add('hidden');
                    if (nameInput) nameInput.style.borderColor = '';
                }

                if (!phoneValid) {
                    errorPhone?.classList.remove('hidden');
                    if (phoneInput) phoneInput.style.borderColor = 'var(--color-coral)';
                    hasError = true;
                } else {
                    errorPhone?.classList.add('hidden');
                    if (phoneInput) phoneInput.style.borderColor = '';
                }

                if (hasError) return;

                form.classList.add('hidden');
                success?.classList.remove('hidden');
            }, { signal });
        }

        resetBtn?.addEventListener('click', showForm, { signal });

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const left = document.querySelector<HTMLElement>('.contact__left');
        const right = document.querySelector<HTMLElement>('.contact__right');

        if (!reduced) {
            if (left) {
                gsap.from(left, {
                    duration: 0.9,
                    ease: 'power3.out',
                    opacity: 0,
                    scrollTrigger: { start: 'top 85%', trigger: left },
                    y: 30,
                });
            }
            if (right) {
                gsap.from(right, {
                    delay: 0.12,
                    duration: 0.9,
                    ease: 'power3.out',
                    opacity: 0,
                    scrollTrigger: { start: 'top 85%', trigger: right },
                    y: 30,
                });
            }
        }

        document.addEventListener('astro:before-preparation', () => {
            controller.abort();
            ScrollTrigger.getAll().forEach(st => st.kill());
        }, { once: true });
    }
</script>
