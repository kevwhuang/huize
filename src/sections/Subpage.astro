---
interface Props {
    cards: { description: string; title: string }[];
    lead: string;
}

const { cards, lead } = Astro.props;
---

<section class="subpage shell">
    <p class="subpage__lead">{lead}</p>
    <ul class="subpage__grid">
        {cards.map(card => (
            <li class="subpage__card">
                <span class="subpage__icon">
                    <span class="subpage__diamond" />
                </span>
                <h3 class="subpage__card-title">{card.title}</h3>
                <p class="subpage__card-text">{card.description}</p>
            </li>
        ))}
    </ul>
    <div class="subpage__cta">
        <h3 class="subpage__cta-title">需要专业的康养与健康咨询？</h3>
        <p class="subpage__cta-text">服务热线 021-5453-0907 &middot; 专属健康顾问为您服务</p>
        <div class="subpage__cta-actions">
            <a class="subpage__cta-primary" href="/about/contact">立即咨询</a>
            <a class="subpage__cta-secondary" href="/">返回首页</a>
        </div>
    </div>
</section>

<style>
    .subpage {
        padding-bottom: clamp(56px, 7vw, 92px);
        padding-top: clamp(56px, 7vw, 92px);
    }

    .subpage__lead {
        color: var(--color-sage-dark);
        font-size: clamp(16px, 1.8vw, 18.5px);
        font-weight: 300;
        line-height: 2.1;
        margin-bottom: 54px;
        margin-left: auto;
        margin-right: auto;
        max-width: 760px;
        text-align: center;
    }

    .subpage__grid {
        display: grid;
        gap: 22px;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        list-style: none;
        margin-bottom: 60px;
        padding: 0;
    }

    .subpage__card {
        background: #ffffff;
        border: 1px solid var(--color-silk);
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(7, 58, 51, .05);
        padding: 30px 28px;
        transition: transform var(--duration-fast), box-shadow var(--duration-fast);
    }

    .subpage__card:hover {
        box-shadow: 0 24px 48px rgba(7, 58, 51, .12);
        transform: translateY(-6px);
    }

    .subpage__card:active {
        transform: translateY(-2px);
    }

    .subpage__icon {
        align-items: center;
        background: var(--color-mint);
        border-radius: 12px;
        display: flex;
        height: 46px;
        justify-content: center;
        margin-bottom: 20px;
        width: 46px;
    }

    .subpage__diamond {
        background: var(--color-jade);
        border-radius: 4px;
        height: 14px;
        transform: rotate(45deg);
        width: 14px;
    }

    .subpage__card-title {
        color: var(--color-pine);
        font-family: var(--font-display);
        font-size: 19px;
        font-weight: 600;
        line-height: 1.4;
        margin-bottom: 12px;
    }

    .subpage__card-text {
        color: var(--color-sage-light);
        font-size: 14.5px;
        font-weight: 300;
        line-height: 1.85;
        margin-bottom: 0;
    }

    .subpage__cta {
        background: var(--color-mint);
        border-radius: 20px;
        padding: clamp(34px, 4vw, 52px);
        text-align: center;
    }

    .subpage__cta-title {
        color: var(--color-pine);
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 2.6vw, 2rem);
        font-weight: 700;
        margin-bottom: 14px;
    }

    .subpage__cta-text {
        color: var(--color-sage);
        font-size: 15.5px;
        font-weight: 300;
        margin-bottom: 28px;
    }

    .subpage__cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        justify-content: center;
    }

    .subpage__cta-primary {
        background: var(--color-jade);
        border-radius: 12px;
        box-shadow: 0 14px 30px rgba(14, 124, 107, .26);
        color: #ffffff;
        font-size: 15.5px;
        font-weight: 500;
        padding: 15px 30px;
        transition: background var(--duration-fast), transform var(--duration-fast);
    }

    .subpage__cta-primary:hover {
        background: var(--color-jade-deep);
        transform: translateY(-2px);
    }

    .subpage__cta-primary:active {
        transform: translateY(0);
    }

    .subpage__cta-secondary {
        background: #ffffff;
        border: 1px solid var(--color-sand);
        border-radius: 12px;
        color: var(--color-pine-light);
        font-size: 15.5px;
        font-weight: 500;
        padding: 15px 28px;
        transition: border-color var(--duration-fast), color var(--duration-fast);
    }

    .subpage__cta-secondary:hover {
        border-color: var(--color-jade);
        color: var(--color-jade);
    }

    .subpage__cta-secondary:active {
        opacity: 0.8;
    }
</style>
