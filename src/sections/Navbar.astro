---
import { Image } from 'astro:assets';

import logoIcon from '@images/logo_icon.webp';
import { ROUTES } from '@lib/utils';

const pathname = Astro.url.pathname;
---

<header class="navbar" data-navbar>
    <div class="navbar__accent" />
    <div class="navbar__bar">
        <nav class="navbar__nav shell">
            <a
                class="navbar__logo"
                href="/"
            >
                <Image
                    alt=""
                    class="navbar__icon"
                    densities={[1, 2]}
                    height={44}
                    quality="max"
                    src={logoIcon}
                />
                <span class="navbar__brand">
                    <span class="navbar__brand-zh">惠泽健康</span>
                    <span class="navbar__brand-en">Huize Health</span>
                </span>
            </a>

            <ul class="navbar__links">
                {ROUTES.map(route => (
                    route.children
                        ? (
                                <li class="navbar__item">
                                    <a
                                        class:list={['navbar__link', { 'navbar__link--active': pathname.startsWith(route.path) && route.path !== '/' }]}
                                        href={route.path}
                                    >
                                        {route.label}
                                    </a>
                                    <div class="navbar__dropdown">
                                        <div class="navbar__dropdown-inner">
                                            {route.children.map(child => (
                                                <a
                                                    class:list={['navbar__dropdown-link', { 'navbar__dropdown-link--active': pathname === child.path }]}
                                                    href={child.path}
                                                >
                                                    {child.label}
                                                </a>
                                            ))}
                                        </div>
                                    </div>
                                </li>
                            )
                        : (
                                <li>
                                    <a
                                        class:list={['navbar__link', { 'navbar__link--active': pathname === route.path }]}
                                        href={route.path}
                                    >
                                        {route.label}
                                    </a>
                                </li>
                            )
                ))}
            </ul>

            <div class="navbar__actions">
                <a
                    class="navbar__cta"
                    href="tel:02154530907"
                >
                    <span class="navbar__cta-icon">
                        <svg
                            fill="none"
                            height="16"
                            stroke="#fff"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            width="16"
                        >
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
                        </svg>
                    </span>
                    <span class="navbar__cta-text">
                        <span class="navbar__cta-label">服务热线 Hotline</span>
                        <span class="navbar__cta-number">021-5453-0907</span>
                    </span>
                </a>

                <button
                    aria-expanded="false"
                    aria-label="菜单"
                    class="navbar__toggle"
                    data-nav-toggle
                    type="button"
                >
                    <span class="navbar__toggle-line" />
                    <span class="navbar__toggle-line" />
                    <span class="navbar__toggle-line" />
                </button>
            </div>
        </nav>
    </div>
</header>

<div
    aria-label="导航菜单"
    aria-modal="true"
    class="navbar__drawer"
    data-drawer
    role="dialog"
>
    <div class="navbar__drawer-backdrop" data-drawer-close />
    <div class="navbar__drawer-panel">
        {ROUTES.map(route => (
            route.children
                ? (
                        <div class="navbar__drawer-group">
                            <a
                                class="navbar__drawer-heading"
                                href={route.path}
                            >
                                {route.label}
                            </a>
                            <ul class="navbar__drawer-pills">
                                {route.children.map(child => (
                                    <li>
                                        <a
                                            class="navbar__drawer-pill"
                                            href={child.path}
                                        >
                                            {child.label}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )
                : (
                        <a
                            class="navbar__drawer-top-link"
                            href={route.path}
                        >
                            {route.label}
                        </a>
                    )
        ))}
        <a
            class="navbar__drawer-cta"
            href="/about/contact"
        >
            立即咨询
        </a>
    </div>
</div>

<script>
    document.addEventListener('astro:page-load', () => {
        const controller = new AbortController();
        const signal = controller.signal;

        const header = document.querySelector<HTMLElement>('[data-navbar]');
        const toggle = document.querySelector<HTMLElement>('[data-nav-toggle]');
        const drawer = document.querySelector<HTMLElement>('[data-drawer]');
        const drawerClose = document.querySelector<HTMLElement>('[data-drawer-close]');

        if (!header) return;

        if (header.dataset.scrolled === undefined && window.scrollY > 14) {
            header.dataset.scrolled = '';
        }

        window.addEventListener('scroll', () => {
            if (window.scrollY > 14) {
                header.dataset.scrolled = '';
            } else {
                delete header.dataset.scrolled;
            }
        }, { passive: true, signal });

        toggle?.addEventListener('click', () => {
            const isOpen = drawer?.dataset.open !== undefined;
            if (isOpen && drawer) {
                delete drawer.dataset.open;
            } else if (drawer) {
                drawer.dataset.open = '';
            }
            toggle.setAttribute('aria-expanded', String(!isOpen));
        }, { signal });

        const closeDrawer = () => {
            if (drawer) delete drawer.dataset.open;
            toggle?.setAttribute('aria-expanded', 'false');
        };

        drawerClose?.addEventListener('click', closeDrawer, { signal });

        drawer?.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', closeDrawer, { signal });
        });
    });
</script>

<style>
    .navbar {
        position: sticky;
        top: 0;
        z-index: 60;
    }

    .navbar__accent {
        background: linear-gradient(90deg, var(--color-jade), var(--color-jade-light) 45%, var(--color-gold));
        height: 3px;
    }

    .navbar__bar {
        backdrop-filter: saturate(180%) blur(14px);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 1px 0 rgba(7, 58, 51, 0.06);
        transition: box-shadow var(--duration-base) ease;
    }

    [data-navbar][data-scrolled] .navbar__bar {
        box-shadow: 0 10px 34px rgba(7, 58, 51, 0.10);
    }

    .navbar__nav {
        align-items: center;
        display: flex;
        gap: 20px;
        height: 74px;
        justify-content: space-between;
    }

    .navbar__logo {
        align-items: center;
        display: flex;
        flex-shrink: 0;
        gap: 13px;
    }

    .navbar__icon {
        display: block;
        height: 44px;
        width: auto;
    }

    .navbar__brand {
        display: flex;
        flex-direction: column;
        line-height: 1;
    }

    .navbar__brand-zh {
        color: var(--color-pine-light);
        font-family: var(--font-display);
        font-size: 21px;
        font-weight: 700;
        letter-spacing: 2px;
    }

    .navbar__brand-en {
        color: var(--color-ash);
        font-family: var(--font-label);
        font-size: 9.5px;
        font-weight: 500;
        letter-spacing: 3.5px;
        margin-top: 5px;
        text-transform: uppercase;
    }

    .navbar__links {
        align-items: center;
        display: flex;
        font-size: 15.5px;
        font-weight: 500;
        gap: 7px;
        list-style: none;
        margin: 0;
        padding: 0;
        white-space: nowrap;
    }

    .navbar__item {
        position: relative;
    }

    .navbar__link {
        color: var(--color-moss);
        flex-shrink: 0;
        padding: 8px 12px;
        transition: color var(--duration-fast);
        white-space: nowrap;
    }

    .navbar__link:hover,
    .navbar__link--active {
        color: var(--color-jade);
    }

    .navbar__link:active {
        opacity: 0.8;
    }

    .navbar__dropdown {
        left: 0;
        opacity: 0;
        padding-top: 12px;
        pointer-events: none;
        position: absolute;
        top: 100%;
        transform: translateY(12px);
        transition: opacity var(--duration-fast) ease, transform var(--duration-fast) ease, visibility var(--duration-fast);
        visibility: hidden;
        width: 230px;
    }

    .navbar__item:last-child .navbar__dropdown {
        left: auto;
        right: 0;
    }

    .navbar__item:hover .navbar__dropdown {
        opacity: 1;
        pointer-events: auto;
        transform: none;
        visibility: visible;
    }

    .navbar__dropdown-inner {
        background: #ffffff;
        border: 1px solid var(--color-silk);
        border-radius: 14px;
        box-shadow: 0 22px 50px rgba(7, 58, 51, 0.14);
        padding: 10px;
    }

    .navbar__dropdown-link {
        border-radius: 9px;
        color: var(--color-moss-light);
        display: block;
        font-size: 14.5px;
        padding: 11px 14px;
        transition: background var(--duration-fast), color var(--duration-fast);
    }

    .navbar__dropdown-link:hover,
    .navbar__dropdown-link--active {
        background: var(--color-mint);
        color: var(--color-jade);
    }

    .navbar__dropdown-link:active {
        background: var(--color-stone);
    }

    .navbar__actions {
        align-items: center;
        display: flex;
        flex-shrink: 0;
        gap: 14px;
    }

    .navbar__cta {
        align-items: center;
        background: var(--color-jade);
        border-radius: 32px;
        box-shadow: 0 12px 26px rgba(14, 124, 107, 0.26);
        color: #ffffff;
        display: flex;
        gap: 11px;
        padding: 9px 20px 9px 11px;
        transition: background var(--duration-fast), transform var(--duration-fast);
    }

    .navbar__cta:hover {
        background: var(--color-jade-deep);
        transform: translateY(-1px);
    }

    .navbar__cta:active {
        transform: translateY(0);
    }

    .navbar__cta-icon {
        align-items: center;
        background: rgba(255, 255, 255, 0.18);
        border-radius: 50%;
        display: flex;
        flex-shrink: 0;
        height: 32px;
        justify-content: center;
        width: 32px;
    }

    .navbar__cta-text {
        display: flex;
        flex-direction: column;
        line-height: 1.18;
    }

    .navbar__cta-label {
        color: rgba(255, 255, 255, 0.72);
        font-family: var(--font-label);
        font-size: 9px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .navbar__cta-number {
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .navbar__toggle {
        align-items: center;
        background: var(--color-mint);
        border: none;
        border-radius: 13px;
        display: none;
        flex-direction: column;
        gap: 5px;
        height: 46px;
        justify-content: center;
        width: 46px;
    }

    .navbar__toggle-line {
        background: var(--color-pine-light);
        border-radius: 2px;
        height: 2px;
        width: 19px;
    }

    .navbar__drawer {
        inset: 77px 0 0 0;
        position: fixed;
        visibility: hidden;
        z-index: 55;
    }

    .navbar__drawer[data-open] {
        visibility: visible;
    }

    .navbar__drawer-backdrop {
        background: rgba(7, 58, 51, 0.45);
        backdrop-filter: blur(2px);
        inset: 0;
        opacity: 0;
        position: absolute;
        transition: opacity var(--duration-base);
    }

    .navbar__drawer[data-open] .navbar__drawer-backdrop {
        opacity: 1;
    }

    .navbar__drawer-panel {
        background: #ffffff;
        max-height: calc(100vh - 77px);
        overflow-y: auto;
        padding: 22px clamp(18px, 5vw, 32px) 40px;
        position: relative;
        transform: translateY(-10px);
        transition: transform var(--duration-base) ease, opacity var(--duration-base);
        opacity: 0;
    }

    .navbar__drawer[data-open] .navbar__drawer-panel {
        opacity: 1;
        transform: none;
    }

    .navbar__drawer-top-link {
        border-bottom: 1px solid var(--color-snow);
        color: var(--color-pine-light);
        display: block;
        font-family: var(--font-display);
        font-size: 19px;
        font-weight: 600;
        padding: 14px 0;
    }

    .navbar__drawer-group {
        border-bottom: 1px solid var(--color-snow);
        padding: 16px 0 6px;
    }

    .navbar__drawer-heading {
        color: var(--color-pine-light);
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 600;
    }

    .navbar__drawer-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        list-style: none;
        margin-bottom: 10px;
        margin-top: 12px;
        padding: 0;
    }

    .navbar__drawer-pill {
        background: var(--color-mint);
        border-radius: 20px;
        color: var(--color-sage-dark);
        font-size: 14px;
        padding: 8px 14px;
    }

    .navbar__drawer-cta {
        background: var(--color-jade);
        border: none;
        border-radius: 12px;
        color: #ffffff;
        display: block;
        font-size: 16px;
        font-weight: 500;
        margin-top: 22px;
        padding: 16px;
        text-align: center;
        width: 100%;
    }

    @media (max-width: 1024px) {
        .navbar__links {
            display: none;
        }

        .navbar__cta {
            display: none;
        }

        .navbar__toggle {
            display: flex;
        }
    }

    @media (min-width: 1025px) {
        .navbar__drawer {
            display: none;
        }
    }
</style>
