---

<section
    aria-labelledby="notfound-title"
    class="notfound"
>
    <h1
        class="notfound__code"
        id="notfound-title"
    >404
    </h1>
    <p class="notfound__text">您访问的页面不存在</p>
    <a class="notfound__link" href="/">返回首页</a>
</section>

<style>
    .notfound {
        align-items: center;
        display: grid;
        justify-items: center;
        min-height: 60vh;
        padding: 80px 20px;
    }

    .notfound__code {
        color: var(--color-pine);
        font-family: var(--font-display);
        font-size: clamp(4rem, 10vw, 8rem);
        font-weight: 700;
        margin-bottom: 16px;
    }

    .notfound__text {
        color: var(--color-sage);
        font-size: 18px;
        margin-bottom: 32px;
    }

    .notfound__link {
        background: var(--color-jade);
        border-radius: 12px;
        color: #ffffff;
        font-size: 15.5px;
        font-weight: 500;
        padding: 15px 30px;
        transition: background var(--duration-fast), transform var(--duration-fast);
    }

    .notfound__link:hover {
        background: var(--color-jade-deep);
        transform: translateY(-2px);
    }

    .notfound__link:active {
        transform: translateY(0);
    }
</style>
