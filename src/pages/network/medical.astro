---
import Layout from '@/Layout.astro';
import Footer from '@sections/Footer.astro';
import Navbar from '@sections/Navbar.astro';
import PageHero from '@sections/PageHero.astro';
import Subpage from '@sections/Subpage.astro';

const CARDS = [
    { description: '专注脑卒中与骨科康复的专业康复医疗机构。', title: '专科康复医院' },
    { description: '对接三级及以上优质医院资源，保障诊疗质量。', title: '三级及以上医院' },
    { description: '百余家合作医疗机构，共建全国医疗服务网络。', title: '100+ 合作机构' },
];
---

<Layout
    description="专科康复医院，三级及以上医院，全国医疗列表。聚焦脑卒中与骨科康复。"
    title="医疗机构 &mdash; 惠泽健康"
>
    <Navbar />
    <main class="flex-1">
        <PageHero section="SERVICE NETWORK &middot; MEDICAL" title="医疗机构" />
        <Subpage
            cards={CARDS}
            lead="专科康复医院，三级及以上医院，全国医疗列表。聚焦脑卒中、骨科等刚需领域，提供专业康复医疗服务。"
        />
    </main>
    <Footer />
</Layout>
