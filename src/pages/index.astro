import Hero from '@sections/Hero.astro';
import Navbar from '@sections/Navbar.astro';
import Network from '@sections/Network.astro';
import News from '@sections/News.astro';
import Services from '@sections/Services.astro';
---

<Layout
    description="惠泽健康是从事康复和护理整合照料的专业平台,提供全流程、一站式的养老服务和健康管理服务。服务热线：021-5453-0907"
